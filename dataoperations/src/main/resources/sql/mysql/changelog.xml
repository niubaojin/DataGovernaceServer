<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="V3.8.0.20251119.01" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="DO_EVENT_TYPE" />
            </not>
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.8.0.20251119.01_DO_TABLE.sql" />
    </changeSet>

    <changeSet id="V3.8.0.20251119.02" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <not>
                <sqlCheck expectedResult="1">
                    select
                        count(*) as cnt
                    from
                        information_schema.TABLES
                    where
                        upper(table_schema) = 'SHPTSTATISTICS'
                        and upper (table_name) = 'SJGC_DATA_TASK';
                </sqlCheck>
            </not>
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.8.0.20251119.02_DO_TABLE.sql" />
    </changeSet>

</databaseChangeLog>