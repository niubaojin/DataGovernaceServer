<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC
        "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.synway.datastandardmanager.dao.master.UnitOrganizationDao">

    <resultMap id="UnitOrganizationResult" type="com.synway.datastandardmanager.pojo.unitManagement.UnitOrganizationPojo">
        <result property="unitCode" column="UNIT_CODE"/>
        <result property="unitName" column="UNIT_NAME"/>
        <result property="unitType" column="UNIT_TYPE"/>
        <result property="unitLevel" column="UNIT_LEVEL"/>
        <result property="unitArea" column="UNIT_AREA"/>
        <result property="unitAreaId" column="UNIT_AREA_ID"/>
        <result property="parentUnitCode" column="P_UNIT_CODE"/>
        <result property="parentUnitName" column="P_UNIT_NAME"/>
        <result property="memo" column="MEMO"/>
        <result property="createTime" column="CREATE_TIME"/>
        <result property="updateTime" column="UPDATE_TIME"/>
    </resultMap>

    <select id="getLeftTreeInfo" resultType="com.synway.datastandardmanager.pojo.unitManagement.UnitOrganizationTree">
        select UNIT_CODE as id,UNIT_NAME as unitName,P_UNIT_CODE as parentId,UNIT_LEVEL as unitLevel from SYNLTE.STANDARDIZE_UNIT_MANAGE
        where UNIT_TYPE=#{unitType}
    </select>

    <select id="searchUnitOrganizationTable" parameterType="com.synway.datastandardmanager.pojo.unitManagement.UnitOrganizationParameter"
            resultType="com.synway.datastandardmanager.pojo.unitManagement.UnitOrganizationPojo" resultMap="UnitOrganizationResult">
        select UNIT_CODE,UNIT_NAME,UNIT_TYPE,UNIT_LEVEL,UNIT_AREA,UNIT_AREA_ID,P_UNIT_CODE,P_UNIT_NAME,MEMO,CREATE_TIME,
        UPDATE_TIME from SYNLTE.STANDARDIZE_UNIT_MANAGE
        <where>
            <if test="searchText != null">
                (upper(UNIT_NAME) like upper(concat('%',concat(#{searchText},'%'))))
                or upper(UNIT_CODE) like upper(concat('%',concat(#{searchText},'%')))
            </if>

            <if test="unitType != null">
                and UNIT_TYPE=#{unitType}
            </if>

            <if test="unitLevelFilterList !=null and unitLevelFilterList.size()>0 ">
                and UNIT_LEVEL in (
                <foreach collection="unitLevelFilterList" item="item" separator="union all" open="(" close=")">
                    select #{item} from dual
                </foreach>
                )
            </if>
        </where>
        <if test="sortOrder !=null and sortOrder != ''">
            order by UNIT_LEVEL ${sortOrder} nulls last
        </if>
    </select>

    <insert id="addOneUnitOrganization" parameterType="com.synway.datastandardmanager.pojo.unitManagement.UnitOrganizationPojo">
        insert into SYNLTE.STANDARDIZE_UNIT_MANAGE(UNIT_CODE,UNIT_NAME,UNIT_TYPE,UNIT_LEVEL,UNIT_AREA,UNIT_AREA_ID,
        P_UNIT_CODE,P_UNIT_NAME,MEMO,CREATE_TIME)
        values (#{unitCode},#{unitName},#{unitType},#{unitLevel,jdbcType=VARCHAR},#{unitArea},#{unitAreaId},#{parentUnitCode,jdbcType=VARCHAR},
        #{parentUnitName,jdbcType=VARCHAR},#{memo,jdbcType=VARCHAR},sysdate)
    </insert>

    <delete id="deleteOneUnitOrganization" parameterType="java.lang.String">
        delete from SYNLTE.STANDARDIZE_UNIT_MANAGE where UNIT_CODE in
        <foreach collection="unitCodes" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
    </delete>

    <update id="updateOneUnitOrganization" parameterType="com.synway.datastandardmanager.pojo.unitManagement.UnitOrganizationPojo">
        update SYNLTE.STANDARDIZE_UNIT_MANAGE set UNIT_NAME=#{unitName},UNIT_TYPE=#{unitType},UNIT_LEVEL=#{unitLevel},P_UNIT_CODE=#{parentUnitCode},
        P_UNIT_NAME=#{parentUnitName},MEMO=#{memo},UPDATE_TIME=sysdate where UNIT_CODE=#{unitCode}
    </update>

    <select id="searchUnitOrganizationCountById" parameterType="java.lang.String" resultType="java.lang.Integer">
        select count(0) from SYNLTE.STANDARDIZE_UNIT_MANAGE where UNIT_CODE=#{unitCode}
    </select>

    <select id="getAreaInfo" resultType="com.synway.datastandardmanager.pojo.FieldCodeVal">
        select f1.CODEID   as codeId,
               f1.CODETEXT as codeText,
               f2.VALTEXT  as valText,
               f2.valvalue as valValue
        from synlte.fieldcode f1
                 inner JOIN synlte.fieldcodeval f2
                            on f1.CODEid = f2.CODEID
                                and f1.PARCODEID = 'GBT2260'
                                and valtext is not null
                                and codetext != valtext
                                and f2.valvalue is not null
--                                 and f2.valvalue like '%00'
    </select>

    <select id="searchUnitOrganizationListByParentId" resultType="com.synway.datastandardmanager.pojo.unitManagement.UnitOrganizationPojo"
            resultMap="UnitOrganizationResult">
        select UNIT_CODE,UNIT_NAME,UNIT_TYPE,UNIT_LEVEL,UNIT_AREA,UNIT_AREA_ID,P_UNIT_CODE,P_UNIT_NAME,MEMO,CREATE_TIME,
        UPDATE_TIME from SYNLTE.STANDARDIZE_UNIT_MANAGE where P_UNIT_CODE=#{parentUnitCode}
    </select>

    <select id="searchAllFilterTable" resultType="com.synway.datastandardmanager.pojo.FilterObject">
        select value, text from(select distinct UNIT_LEVEL as value,
        'unitLevel' as text from synlte.STANDARDIZE_UNIT_MANAGE where UNIT_LEVEL is not null order by UNIT_LEVEL asc)
    </select>


</mapper>