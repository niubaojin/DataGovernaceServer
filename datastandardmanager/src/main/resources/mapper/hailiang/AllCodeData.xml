<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >


<mapper namespace="com.synway.datastandardmanager.mapper.AllCodeDataMapper">

    <select id="getSelectObjectByName" resultType="com.synway.datastandardmanager.entity.vo.KeyValueVO">
        select code_value as value, code_text as label
          from all_code_data
         where upper(CODE_ID) = upper(#{name})
    </select>

</mapper>