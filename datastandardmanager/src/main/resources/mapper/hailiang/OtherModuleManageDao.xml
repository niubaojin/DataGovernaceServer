<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC   
    "-//mybatis.org//DTD Mapper 3.0//EN"  
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.synway.datastandardmanager.dao.master.OtherModuleManageDao">


    <select id="getOtherModuleObjectCreated" resultType="java.lang.String">
        select upper(TABLEID)   from MODULE_CREATED_OBJECT where upper(MODULE_NAME) = upper(#{moduleName})
    </select>

    <select id="getObjectCreatedById" resultType="java.lang.Integer">
        select count(0) from MODULE_CREATED_OBJECT
        where upper(MODULE_NAME) = upper(#{moduleName}) and upper(TABLEID) = upper(#{tableId})
    </select>

    <insert id="addOtherModuleCreated" parameterType="com.synway.datastandardmanager.pojo.sourcedata.OtherModuleManageCreated">
        insert into MODULE_CREATED_OBJECT(TABLEID,MODULE_NAME, OBJECTID) values(
           #{tableId},#{moduleName},#{objectId}
        )
    </insert>

</mapper>