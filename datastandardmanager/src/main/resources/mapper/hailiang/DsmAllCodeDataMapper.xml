<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >


<mapper namespace="com.synway.datastandardmanager.mapper.DsmAllCodeDataMapper">

    <select id="getSelectObjectByName" resultType="com.synway.datastandardmanager.entity.vo.ValueTextVO">
        select code_value as value, code_text as text
          from DSM_ALL_CODE_DATA
         where upper(CODE_ID) = upper(#{name})
    </select>

</mapper>