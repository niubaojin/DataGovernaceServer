<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC
        "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.synway.datastandardmanager.dao.standard.ObjectDao">

    <select id="countObjectByTableId" resultType="java.lang.Integer">
        select count(1) from synlte.OBJECT where TABLEID = #{tableId} or TABLENAME = #{tableName}
    </select>

</mapper>