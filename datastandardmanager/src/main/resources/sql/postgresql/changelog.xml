<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!--建表-->
    <changeSet id="3.6.0.20250318.01" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="STANDARDIZE_INPUTOBJECT" />
            </not>
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.6.0.20240813.01_DSM_TABLE.sql"/>
    </changeSet>

    <!--建视图-->
    <changeSet id="3.6.0.20250318.02" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists viewName="v_classify_info" />
            </not>
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.6.0.20240813.01_DSM_VIEW.sql"/>
    </changeSet>

    <!--初始化数据-->
    <changeSet id="3.6.0.20250318.03" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <tableIsEmpty tableName="all_code_data" />
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.6.0.20240813.01_DSM_INIT.sql" />
    </changeSet>

    <changeSet id="check_and_insert" author="nbj">
        <!--判断数据是否存在-->
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                select count(*) from all_code_data where code_id = 'SYNLTEFIELD_STATUS' and code_value = '07'
            </sqlCheck>
        </preConditions>
        <!--不存在则插入-->
        <insert tableName="all_code_data">
            <column name="id" value="07"></column>
            <column name="code_id" value="SYNLTEFIELD_STATUS"></column>
            <column name="code_value" value="07"></column>
            <column name="code_text" value="停用"></column>
            <column name="memo" value="数据元页面中的状态-停用"></column>
        </insert>
    </changeSet>

</databaseChangeLog>