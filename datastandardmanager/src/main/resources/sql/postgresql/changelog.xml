<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!--建表-->
    <changeSet id="3.6.0.20250318.01" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="STANDARDIZE_INPUTOBJECT" />
            </not>
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.6.0.20240813.01_DSM_TABLE.sql"/>
    </changeSet>

    <!--建视图-->
    <changeSet id="3.6.0.20250318.02" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists viewName="v_classify_info" />
            </not>
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.6.0.20240813.01_DSM_VIEW.sql"/>
    </changeSet>

    <!--建表-->
    <changeSet id="3.8.0.20251211.02" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="DSM_LABEL_CODE_TABLE" />
            </not>
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.8.0.20251211.02_DSM_TABLE.sql"/>
    </changeSet>

    <!--初始化数据-->
    <changeSet id="3.6.0.20250318.03" author="nbj" >
        <preConditions onFail="MARK_RAN">
            <tableIsEmpty tableName="DSM_ALL_CODE_DATA" />
        </preConditions>
        <sqlFile relativeToChangelogFile="true" path="V3.6.0.20240813.01_DSM_INIT.sql" />
    </changeSet>

    <changeSet id="V3.8.0.20251211.03" author="nbj">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="SOURCEINFO" />
            <sqlCheck expectedResult="0">
                select count(*) from DSM_SOURCEINFO
            </sqlCheck>
        </preConditions>
        <sql>
            insert into DSM_MODULE_CREATED_OBJECT select * from MODULE_CREATED_OBJECT;
            insert into DSM_SOURCEINFO select * from SOURCEINFO;
            insert into DSM_SOURCE_FIELD_INFO select * from SOURCE_FIELD_INFO;
            insert into DSM_STANDARD_TABLE_CREATED select * from STANDARD_TABLE_CREATED;
        </sql>
    </changeSet>

</databaseChangeLog>